# Strategy Factory — Environment Variables Template
# Copy this file to ".env" for local use, or set the same names in Railway.

# Dashboard authentication
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me

# Alpaca PAPER trading
ALPACA_API_KEY=your-paper-api-key
ALPACA_API_SECRET=your-paper-api-secret

# Persistent paths. Docker already sets these for Railway, but they are useful
# when running locally with a custom data directory.
STRATEGY_FACTORY_DATA_DIR=data
STRATEGY_FACTORY_REPORT_DIR=reports

# Scheduler intervals in minutes.
# AUTO_TRADE_INTERVAL_MIN controls the local simulator worker.
# ALPACA_AUTO_TRADE_INTERVAL_MIN controls Alpaca paper auto-trading.
AUTO_TRADE_INTERVAL_MIN=60
ALPACA_AUTO_TRADE_INTERVAL_MIN=60

# Intraday signal/risk tuning
INTRADAY_GATE_ENABLED=true
INTRADAY_MIN_SIGNAL_CONFIDENCE=0.56
INTRADAY_EXTREME_ATR_PCT=8.0
INTRADAY_MIN_VOLUME_RATIO=0.35
INTRADAY_BASE_STOP_LOSS_PCT=2.2
INTRADAY_BASE_TAKE_PROFIT_PCT=4.2
INTRADAY_BASE_TRAILING_STOP_PCT=1.6
INTRADAY_MAX_HOLD_HOURS=18
